{
  "name": "eufy-viewer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "build": "rm -rf .next && next build",
    "start": "NODE_ENV=production node server.js",
    "lint": "oxlint -c oxlint.config.mjs src server.js",
    "lint:fix": "oxlint -c oxlint.config.mjs --fix src server.js",
    "format": "oxfmt -c oxfmt.config.mjs --write src server.js",
    "format:check": "oxfmt -c oxfmt.config.mjs --check src server.js",
    "prepare": "lefthook install",
    "test": "node --test"
  },
  "dependencies": {
    "@reactuses/core": "^6.3.2",
    "clsx": "^2.1.1",
    "eufy-security-client": "^3.8.0",
    "jmuxer": "^2.0.5",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "swr": "^2.4.1",
    "ws": "^8.18.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@tailwindcss/postcss": "^4.3.0",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "ultracite": "^7.8.1"
  },
  "engines": {
    "node": ">=20.9"
  }
}
