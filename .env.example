# Copy this file to .env.local and fill in your Eufy account.
# You can also leave these blank and log in via the browser wizard on first run;
# the app will write your credentials back to .env.local automatically.

# Eufy account (a dedicated secondary account is strongly recommended)
EUFY_USERNAME=
EUFY_PASSWORD=
EUFY_COUNTRY=NL

# Server port for the combined Next.js + WebSocket server (default: 3000)
PORT=3000
